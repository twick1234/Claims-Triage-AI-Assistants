# Anthropic API Key — required for AI agent functionality
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent mode: simulation (default) or hardware
# - simulation: all 5 agents run as in-process Next.js API routes (laptop only)
# - hardware:   each agent is a physical Sipeed LicheeRV Nano W board via HTTP
AGENT_MODE=simulation

# Hardware mode: board URLs (only needed when AGENT_MODE=hardware)
# Each board runs PicoClaw (github.com/sipeed/picoclaw) as an HTTP gateway to Claude.
# Assign static IPs in your router DHCP reservation before setting these.
GRACE_URL=http://192.168.1.51:8001
SWIFT_URL=http://192.168.1.52:8002
KARA_URL=http://192.168.1.53:8003
PHOENIX_URL=http://192.168.1.54:8004
TRIAGE_URL=http://192.168.1.55:8005
